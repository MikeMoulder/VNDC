APP_NAME=Verifiable AI Token Verdict API
API_PREFIX=/api
ENVIRONMENT=development

FRONTEND_ORIGIN=http://localhost:3000

COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
DEXSCREENER_BASE_URL=https://api.dexscreener.com/latest/dex

OPENGRADIENT_ENABLED=true
OG_PRIVATE_KEY=your_opengradient_private_key_here
OPENGRADIENT_MODEL=openai/gpt-4.1-2025-04-14
OPENGRADIENT_SETTLEMENT_MODE=SETTLE_BATCH
OPENGRADIENT_APPROVAL_AMOUNT=5.0

# On-chain ONNX volatility tool via AlphaSense (Alpha devnet).
# The tool submits a transaction to the OpenGradient devnet (chain 10740).
# If the devnet inference nodes are down or the model CID is unavailable,
# the API gracefully degrades — the LLM verdict still works.
OPENGRADIENT_ENABLE_VOLATILITY_TOOL=false
OPENGRADIENT_VOLATILITY_MODEL_CID=hJD2Ja3akZFt1A2LT-D_1oxOCz_OtuGYw4V9eE1m39M
ALLOW_MOCK_OPENGRADIENT=false

RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
CACHE_TTL_SECONDS=120
